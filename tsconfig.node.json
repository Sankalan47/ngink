{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/node",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "esModuleInterop": true,
    "types": ["node"]
  },
  "angularCompilerOptions": {
    "strictTemplates": true
  },
  "include": ["src/**/*.ts", "examples/**/*.ts"],
  "exclude": ["src/**/*.spec.ts"]
}
